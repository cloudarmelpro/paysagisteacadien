# Copier en `.env` et remplacer par les vraies valeurs (jamais versionnées).

# URL Neon POOLÉE (hôte en `-pooler`) : Prisma 7 passe par le driver adapter pg,
# une URL directe épuiserait les connexions en serverless.
DATABASE_URL="postgresql://user:password@ep-exemple-123456-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"

# --- Envoi des notifications de formulaire (Resend) ---
# Sans RESEND_API_KEY, les soumissions restent enregistrées en base et l'envoi
# courriel est simplement sauté (aucune erreur). Définir la clé active l'envoi,
# sans redéploiement.
# Clé API : https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Expéditeur : doit appartenir à un domaine vérifié dans Resend. Pour un test
# immédiat sans domaine, garder onboarding@resend.dev (livre à l'adresse du
# compte Resend uniquement).
RESEND_FROM="Paysagiste Acadien <onboarding@resend.dev>"
# Destinataire des soumissions (par défaut : l'adresse de contact du site).
RESEND_TO="paysagisteacadien@outlook.com"
